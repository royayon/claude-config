# Copy to .env and fill in real values. .env is gitignored.

# Anthropic API key, used by the pdf-clause-extract skill.
ANTHROPIC_API_KEY=

# MLflow tracking URI for the mlflow-lookup MCP server.
# Defaults to a local ./mlruns directory if unset.
MLFLOW_TRACKING_URI=./mlruns

# Databricks workspace and personal access token, used by the
# databricks-submit-poll skill. Not needed for anything else.
DATABRICKS_HOST=
DATABRICKS_TOKEN=
